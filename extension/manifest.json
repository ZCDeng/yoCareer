{
  "manifest_version": 3,
  "name": "yoCareer",
  "version": "2.0.0",
  "description": "Save job postings from Chinese recruiting platforms to yoCareer daemon",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "yoCareer"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.zhipin.com/*",
        "*://*.lagou.com/*",
        "*://*.zhaopin.com/*"
      ],
      "js": ["content/extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
